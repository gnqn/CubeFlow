Chain S-C1: Stock Volatility Anomaly Detection
This chain analyzes high-frequency stock trading data to detect intraday volatility anomalies and identify stocks with unusually active abnormal movements. It starts by computing the 2-minute rolling max-min range (Q1-Q3) and its ratio to the rolling min (Q4), converting to percentage (Q5). It then detects outliers by subtracting the daily 75th percentile (Q6) and filtering positive deviations (Q7-Q8). Finally, it counts anomalous minutes per stock per day (Q9), identifies days with abnormally high counts via another 75th percentile filter (Q10-Q11), and outputs stocks with persistently high anomaly frequency (Q12).

-- Input Query: S-C1.Q1
Q1:	SELECT Date,Code,Time,Max(High) OVER(ORDER BY Date,Code,Time ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS m0 FROM Stock ORDER BY Date,Code,Time

-- Input Query: S-C1.Q2
Q2:	SELECT Date,Code,Time,Min(Low) OVER(ORDER BY Date,Code,Time ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS m0 FROM Stock ORDER BY Date,Code,Time

Q3:	SELECT Q1.Date,Q1.Code,Q1.Time,Q1.m0 - Q2.m0 AS m0 FROM Q1, Q2 WHERE Q1.Date=Q2.Date AND Q1.Code=Q2.Code AND Q1.Time=Q2.Time 
    ORDER BY Q1.Date,Q1.Code,Q1.Time

Q4:	SELECT Q3.Date,Q3.Code,Q3.Time,Q3.m0 / Q2.m0 AS m0 FROM Q3, Q2 WHERE Q3.Date=Q2.Date AND Q3.Code=Q2.Code AND Q3.Time=Q2.Time 
    ORDER BY Q3.Date,Q3.Code,Q3.Time

Q5:	SELECT Date,Code,Time,m0 * 100 AS m0 FROM Q4 WHERE m0!=0

Q6:	SELECT Date,Quantile(m0, 0.75) AS m0 FROM Q5 GROUP BY Date ORDER BY Date

Q7:	SELECT Q5.Date,Q5.Code,Q5.Time,Q5.m0 - Q6.m0 AS m0 FROM Q5, Q6 WHERE Q5.Date=Q6.Date ORDER BY Q5.Date,Q5.Code,Q5.Time

Q8:	SELECT Date,Code,Time,m0 AS m0 FROM Q7 WHERE m0>0

Q9:	SELECT Date,Code,COUNT(*) AS m0 FROM Q8 GROUP BY Date,Code ORDER BY Date,Code

Q10:	SELECT Date,Quantile(m0, 0.75) AS m0 FROM Q9 GROUP BY Date ORDER BY Date

Q11:	SELECT Q9.Date,Q9.Code,Q9.m0 - Q10.m0 AS m0 FROM Q9, Q10 WHERE Q9.Date=Q10.Date ORDER BY Q9.Date,Q9.Code

Q12:	SELECT Date,Code,m0 AS m0 FROM Q11 WHERE m0>0
